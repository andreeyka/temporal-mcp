# Copy to .env: cp env.examples .env

# --- Server (MCP_*) ---
MCP_SERVER_NAME=temporal-multi-namespace
MCP_MASK_ERROR_DETAILS=true
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=http
MCP_STATELESS_HTTP=true
MCP_READ_ONLY=false
MCP_TOOL_SEARCH=true                     # false = expose the full tool catalog instead of search_tools/call_tool

# --- Identity Provider anchor (typically a Keycloak realm) ---
IDP_ISSUER=https://sso.example.com/realms/demo
IDP_AUDIENCE=temporal-api
# token_url is derived from the issuer; override only for split deployments
# (JWKS is always derived internally by KeycloakAuthProvider and is not configurable here):
# IDP_TOKEN_URL=https://sso.example.com/realms/demo/protocol/openid-connect/token

# --- Incoming auth (MCP_AUTH_*) — how MCP clients authenticate to this server ---
MCP_AUTH_MODE=none                       # none | keycloak (RFC 9728 client-initiated SSO)
# MCP_AUTH_BASE_URL=https://mcp.example.com   # required for keycloak mode (advertised resource URL)
# MCP_AUTH_AUDIENCE=temporal-api          # per-task override; falls back to IDP_AUDIENCE
# keycloak mode validates the incoming JWT 'aud' by default: set IDP_AUDIENCE above or MCP_AUTH_AUDIENCE here
MCP_AUTH_REQUIRE_AUDIENCE=true            # false = run keycloak mode WITHOUT aud validation (INSECURE; logs a startup warning)
# Optional extra authorization after valid issuer/audience/signature checks:
# MCP_AUTH_CLAIM_EXPR="\"Example-Admins\" in groups || \"Example-Operators\" in groups"

# --- Temporal (TEMPORAL_*) ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_AUTH_MODE=service               # service | passthrough | exchange
TEMPORAL_POOL_MAX=64
# TEMPORAL_API_KEY=                       # static API key (service mode, optional)

# Outbound service (client-credentials service account):
TEMPORAL_OIDC_CLIENT_ID=temporal-mcp-svc
# TEMPORAL_OIDC_CLIENT_SECRET=change-me
# TEMPORAL_OIDC_SCOPE=temporal
# TEMPORAL_OIDC_AUDIENCE=temporal-api     # per-task override; falls back to IDP_AUDIENCE
# TEMPORAL_OIDC_TOKEN_URL=...             # per-task override; falls back to IDP_TOKEN_URL
# TEMPORAL_OIDC_REFRESH_SECONDS=300

# Outbound exchange (RFC 8693):
# TEMPORAL_EXCHANGE_CLIENT_ID=temporal-mcp-exchange
# TEMPORAL_EXCHANGE_CLIENT_SECRET=change-me
# TEMPORAL_EXCHANGE_AUDIENCE=temporal-api # per-task override; falls back to IDP_AUDIENCE
# TEMPORAL_EXCHANGE_SCOPE=temporal
# TEMPORAL_EXCHANGE_TOKEN_URL=...         # per-task override; falls back to IDP_TOKEN_URL
